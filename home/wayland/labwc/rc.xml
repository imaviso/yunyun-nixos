<?xml version="1.0"?>
<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->
<labwc_config>
  <core>
    <decoration>server</decoration>
    <gap>0</gap>
    <adaptiveSync>yes</adaptiveSync>
    <allowTearing>no</allowTearing>
    <autoEnableOutputs>no</autoEnableOutputs>
    <reuseOutputMode>no</reuseOutputMode>
    <xwaylandPersistence>no</xwaylandPersistence>
  </core>
  <desktops number="1"/>
  <windowSwitcher show="yes" style="thumbnail" preview="yes" outlines="yes" allWorkspaces="no">
    <fields>
      <field content="icon" width="5%" />
      <field content="desktop_entry_name" width="30%" />
      <field content="title" width="65%" />
    </fields>
  </windowSwitcher>
  <focus>
    <followMouse>yes</followMouse>
  </focus>
  <theme>
    <name>openbox-3</name>
    <cornerRadius>0</cornerRadius>
    <font name="SFProText Nerd Font" size="9"/>
    <dropShadows>yes</dropShadows>
    <keepBorder>no</keepBorder>
  </theme>
  <icon>Colloid-Dark</icon>
  <libinput>
    <device category="Razer Razer Viper Mini">
      <naturalScroll>no</naturalScroll>
      <leftHanded/>
      <pointerSpeed>0</pointerSpeed>
      <accelProfile>flat</accelProfile>
      <tap>yes</tap>
      <tapButtonMap/>
      <tapAndDrag/>
      <dragLock/>
      <middleEmulation/>
      <disableWhileTyping/>
      <clickMethod/>
      <sendEventsMode/>
      <calibrationMatrix/>
      <scrollFactor>1.0</scrollFactor>
    </device>
    <device category="Compx Nearlink Mouse Dongle">
      <naturalScroll>no</naturalScroll>
      <leftHanded/>
      <pointerSpeed>0</pointerSpeed>
      <accelProfile>flat</accelProfile>
      <tap>yes</tap>
      <tapButtonMap/>
      <tapAndDrag/>
      <dragLock/>
      <middleEmulation/>
      <disableWhileTyping/>
      <clickMethod/>
      <sendEventsMode/>
      <calibrationMatrix/>
      <scrollFactor>1.0</scrollFactor>
    </device>
  </libinput>
  <keyboard>
    <repeatRate>35</repeatRate>
    <repeatDelay>250</repeatDelay>
    <default/>
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="app2unit -- footclient"/>
    </keybind>
    <keybind key="W-Space">
      <action name="Execute" command="app2unit -- kitty"/>
    </keybind>
    <keybind key="W-S-q">
      <action name="Close"/>
    </keybind>
    <!-- <keybind key="W-a"> -->
    <!--   <action name="Execute" command="walker" /> -->
    <!-- </keybind> -->
    <!-- <keybind key="W-d"> -->
    <!--   <action name="Execute" command="sh -c 'pkill anyrun || anyrun'"/> -->
    <!-- </keybind> -->
    <keybind key="W-d">
      <action name="Execute" command="dms ipc call spotlight toggle"/>
    </keybind>
    <keybind key="W-S-e">
      <action name="Execute" command="app2unit -- nautilus"/>
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="app2unit -- foot -e yazi"/>
    </keybind>
    <keybind key="W-f">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="W-s">
      <action name="Execute">
        <command>sh -c 'grim -g "$(slurp)" - | swappy -f -'</command>
      </action>
    </keybind>
    <keybind key="W-c">
      <action name="Execute">
        <command>dms ipc call clipboard toggle</command>
      </action>
    </keybind>
    <keybind key="W-p">
      <action name="Execute" command="hyprpicker -a"/>
    </keybind>
    <keybind key="W-t">
      <action name="Execute" command="~/.config/labwc/scripts/ocr-eng.sh"/>
    </keybind>
    <keybind key="W-j">
      <action name="Execute" command="~/.config/labwc/scripts/ocr-jp.sh"/>
    </keybind>
    <!-- <keybind key="W-l"> -->
    <!--   <action name="Execute" command="sh -c 'qs -c noctalia-shell ipc call sessionMenu toggle'"/> -->
    <!-- </keybind> -->
    <keybind key="W-l">
      <action name="Execute" command="dms ipc call powermenu toggle"/>
    </keybind>
    <keybind key="W-n">
      <action name="Execute" command="dms ipc call notifications toggle"/>
      </keybind> 
    <keybind key="W-m">
      <action name="Execute" command="dms ipc call processlist toggle"/>
    </keybind>
    <keybind key="W-w">
      <action name="Execute" command="dms ipc call notepad toggle"/>
    </keybind>
    <keybind key="W-S-Escape">
      <action name="Execute" command="dms ipc call control-center toggle"/>
    </keybind>
    <keybind key="W-Comma">
      <action name="Execute" command="dms ipc call settings toggle"/>
    </keybind>
    <!-- <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind> -->
    <!-- <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind> -->
    <!-- <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind> -->
    <!-- <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind> -->
    <!-- <keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind> -->
    <!-- <keybind key="W-S-1"> <action name="SendToDesktop" to="1" /> </keybind> -->
    <!-- <keybind key="W-S-2"> <action name="SendToDesktop" to="2" /> </keybind> -->
    <!-- <keybind key="W-S-3"> <action name="SendToDesktop" to="3" /> </keybind> -->
    <!-- <keybind key="W-S-4"> <action name="SendToDesktop" to="4" /> </keybind> -->
    <!-- <keybind key="W-S-5"> <action name="SendToDesktop" to="5" /> </keybind> -->
    <keybind key="W-S-1">
      <action name="MoveToOutput" direction="left"/>
    </keybind>
    <keybind key="W-S-2">
      <action name="MoveToOutput" direction="right"/>
    </keybind>
    <keybind key="W-1">
      <action name="FocusOutput" direction="left"/>
    </keybind>
    <keybind key="W-2">
      <action name="FocusOutput" direction="right"/>
    </keybind>
    <keybind key="W-C-r">
      <action name="Reconfigure"/>
    </keybind>
    <keybind key="W-b">
      <action name="ToggleDecorations"/>
    </keybind>
    <keybind key="W-a">
      <action name="Iconify"/>
    </keybind>
    <keybind key="W-S-plus">
      <action name="ResizeRelative" right="50" bottom="50" top="50" left="50"/>
    </keybind>
    <keybind key="W-S-minus">
      <action name="ResizeRelative" right="-50" bottom="-50" top="-50" left="-50"/>
    </keybind>
    <!-- <keybind key="XF86AudioRaiseVolume"> -->
    <!--   <action name="execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+" /> -->
    <!-- </keybind> -->
    <!-- <keybind key="XF86AudioLowerVolume"> -->
    <!--   <action name="execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" /> -->
    <!-- </keybind> -->
    <!-- <keybind key="XF86AudioMute"> -->
    <!--   <action name="execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" /> -->
    <!-- </keybind> -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="execute" command="dms ipc call audio increment 3" />
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="execute" command="dms ipc call audio decrement 3" />
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="execute" command="dms ipc call audio mute" />
    </keybind>
  </keyboard>

  <mouse>
    <default/>
    <!-- Show a custom menu on desktop right click -->
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="some-custom-menu"/>
      </mousebind>
    </context>
    <context name="Frame">
      <mousebind button="W-Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="W-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="W-Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="W-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
  </mouse>
  <windowRules>
    <windowRule identifier="footclient">
      <action name="ResizeTo" width="1000" height="800"/>
      <action name="AutoPlace" policy="center"/>
    </windowRule>
    <windowRule identifier="foot">
      <action name="ResizeTo" width="1000" height="800"/>
      <action name="AutoPlace" policy="center"/>
    </windowRule>
    <windowRule identifier="kitty">
      <action name="ResizeTo" width="1000" height="800"/>
      <action name="AutoPlace" policy="center"/>
    </windowRule>
    <windowRule identifier="ghostty">
      <action name="ResizeTo" width="1000" height="800"/>
      <action name="AutoPlace" policy="center"/>
    </windowRule>
  </windowRules>
</labwc_config>
