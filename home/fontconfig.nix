{
  fonts.fontconfig = {
    enable = true;
    antialiasing = true;
    hinting = "slight";
    subpixelRendering = "rgb";

    defaultFonts = {
      serif = [ "SFProText Nerd Font" ];
      sansSerif = [ "SFProText Nerd Font" ];
      monospace = [ "SFMono Nerd Font" ];
      emoji = [ "Noto Color Emoji" ];
    };
  };
}
